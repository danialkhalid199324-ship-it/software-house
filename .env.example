# --- Contact form delivery -------------------------------------------------
# Copy this file to `.env.local` (dev) or set these in your host (e.g. Vercel).
# Enquiries submitted through the site's contact form are delivered using the
# channels you configure below. At least one is required in production.

# Where enquiries are sent (defaults to hello@trivasofttechnology.com.au).
CONTACT_TO=hello@trivasofttechnology.com.au

# Email delivery via Resend (https://resend.com) — REST API, no SDK needed.
# 1. Create a Resend account and verify the trivasofttechnology.com.au domain.
# 2. Create an API key and paste it here.
RESEND_API_KEY=

# The "from" address must be on a domain verified in Resend.
CONTACT_FROM="TrivaSoft Website <noreply@trivasofttechnology.com.au>"

# Optional: also forward each enquiry to a CRM / automation webhook
# (Zapier, Make, n8n, etc.). Leave blank if unused.
CONTACT_WEBHOOK_URL=
